{
  "name": "ai-internal-helpdesk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/api && npm run build --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:hostinger": "npm run build --workspace=apps/web && rm -rf .next && ln -sfn apps/web/.next .next",
    "db:generate": "npm run prisma:generate --workspace=apps/api",
    "db:migrate": "npm run prisma:migrate --workspace=apps/api",
    "db:push": "npm run prisma:push --workspace=apps/api",
    "db:studio": "npm run prisma:studio --workspace=apps/api",
    "db:setup": "bash scripts/setup-local-db.sh",
    "tunnel:oauth": "bash scripts/start-oauth-tunnel.sh",
    "tunnel:web": "bash scripts/start-web-tunnel.sh",
    "tunnel:zoom": "bash scripts/start-oauth-tunnel.sh"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
